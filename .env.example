# MPG Finance v2 — Environment Variables
# Copy file ini jadi .env dan isi nilainya
# JANGAN commit .env ke Git!

# ── Database ──────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=mpg_finance

# ── Auth ──────────────────────────────────────
# Generate dengan: openssl rand -base64 32
JWT_SECRET=generate_secret_here_min_32_chars
JWT_EXPIRES_IN=8h

# ── App ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Google Sheets (opsional) ──────────────────
# Jangan simpan di sini — gunakan Secret Manager di production
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_SHEET_ID=
